// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client-js"
  output          = "../app/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgres"
}

enum Role {
  OWNER
  MEMBER
}

//
model User {
  id               String          @id @default(dbgenerated("uuidv7()")) @db.Uuid
  email            String          @unique
  password         String
  name             String
  avatar           String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  projects         Project[]
  projectMembers   ProjectMember[]
  authoredTasks    Task[]          @relation("AuthorTasks")
  assignedTasks    Task[]          @relation("AssigneeTasks")
  createdInvites   ProjectInvite[] @relation("CreatedBy")
  usedInvites      ProjectInvite[] @relation("UsedInvites")
  authoredSections Section[]       @relation("AuthorSections")
}

model Project {
  id             String          @id @default(dbgenerated("uuidv7()")) @db.Uuid
  name           String
  description    String?
  owner          User            @relation(fields: [ownerId], references: [id])
  ownerId        String          @db.Uuid
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  projectMembers ProjectMember[]
  projectInvites ProjectInvite[]
  sections       Section[]
}

model ProjectMember {
  id              String          @id @default(dbgenerated("uuidv7()")) @db.Uuid
  project         Project         @relation(fields: [projectId], references: [id])
  projectId       String          @db.Uuid
  user            User            @relation(fields: [userId], references: [id])
  userId          String          @db.Uuid
  role            Role
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  sectionAccesses SectionAccess[]
}

model ProjectInvite {
  id                    String                @id @default(dbgenerated("uuidv7()")) @db.Uuid
  project               Project               @relation(fields: [projectId], references: [id])
  projectId             String                @db.Uuid
  token                 String                @unique
  createdBy             User                  @relation("CreatedBy", fields: [createdById], references: [id])
  createdById           String                @db.Uuid
  usedByUser            User?                 @relation("UsedInvites", fields: [usedByUserId], references: [id])
  usedByUserId          String?               @db.Uuid
  expiresAt             DateTime              @default(dbgenerated("now() + interval '10 days'"))
  createdAt             DateTime              @default(now())
  inviteSectionAccesses InviteSectionAccess[]

  @@index([expiresAt])
}

model Section {
  id                    String                @id @default(dbgenerated("uuidv7()")) @db.Uuid
  project               Project               @relation(fields: [projectId], references: [id])
  projectId             String                @db.Uuid
  name                  String
  order                 Float
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  deletedAt             DateTime?
  sectionAccesses       SectionAccess[]
  boards                Board[]
  inviteSectionAccesses InviteSectionAccess[]
  author                User                  @relation("AuthorSections", fields: [authorId], references: [id])
  authorId              String                @db.Uuid
}

model InviteSectionAccess {
  id        String        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  invite    ProjectInvite @relation(fields: [inviteId], references: [id])
  inviteId  String        @db.Uuid
  section   Section       @relation(fields: [sectionId], references: [id])
  sectionId String        @db.Uuid
}

model SectionAccess {
  id              String        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  section         Section       @relation(fields: [sectionId], references: [id])
  sectionId       String        @db.Uuid
  projectMember   ProjectMember @relation(fields: [projectMemberId], references: [id])
  projectMemberId String        @db.Uuid
}

model Board {
  id        String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  section   Section  @relation(fields: [sectionId], references: [id])
  sectionId String   @db.Uuid
  name      String
  order     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]
}

model Task {
  id         String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  board      Board    @relation(fields: [boardId], references: [id])
  boardId    String   @db.Uuid
  author     User     @relation("AuthorTasks", fields: [authorId], references: [id])
  authorId   String   @db.Uuid
  assignee   User?    @relation("AssigneeTasks", fields: [assigneeId], references: [id])
  assigneeId String?  @db.Uuid
  order      Float
  metadata   Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
