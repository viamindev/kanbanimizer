{
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    "style": "off",
    "pedantic": "off",
    "restriction": "off"
  },
  "rules": {
    "unicorn/no-empty-file": "off"
  },
  "ignorePatterns": [
    "dist/**",
    "build/**",
    "coverage/**",
    "node_modules/**",
    "frontend/dist/**",
    "backend/dist/**"
  ]
}
