NODE_ENV=development
PORT=3000

# Neon / Postgres connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# min 32 chars each — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace_me_with_a_long_random_secret_min_32
JWT_REFRESH_SECRET=replace_me_with_another_long_random_secret_32

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
